{
  "name": "re-forest-api",
  "version": "1.0.0",
  "description": "Greening Belize - Hono API with Bun runtime",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run src/seed.ts",
    "seed:achievements": "bun run src/db/seed-achievements.ts",
    "vercel-build": "node scripts/build-vercel.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@neondatabase/serverless": "^0.10.4",
    "argon2-wasm-edge": "^1.0.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "jsonwebtoken": "^9.0.2",
    "sharp": "^0.33.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.9",
    "drizzle-kit": "^0.30.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.3"
  }
}
