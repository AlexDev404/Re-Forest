{
  "name": "re-forest-api",
  "version": "1.0.0",
  "description": "Greening Belize - Hono API with Bun runtime",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run src/seed.ts",
    "vercel-build": "true"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "@neondatabase/serverless": "^0.10.4",
    "argon2": "^0.43.0",
    "jsonwebtoken": "^9.0.2",
    "sharp": "^0.33.5",
    "zod": "^4.0.0",
    "firebase-admin": "^13.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.9",
    "drizzle-kit": "^0.30.2",
    "typescript": "^5.8.3"
  }
}
